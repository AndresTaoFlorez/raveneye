# Copy to .env and adjust. All variables are optional; defaults shown.

# URL the shared browser opens on startup and the default mission target.
# Use http://sample-app:3000 for the bundled sample application,
# http://host.docker.internal:<port> for an app running on the host,
# or any authorized http(s) URL.
UI_OBSERVER_TARGET_URL=http://sample-app:3000

# Comma-separated hostnames the browser is allowed to reach.
# Requests to other hosts are refused by the URL policy.
UI_OBSERVER_ALLOWED_HOSTS=sample-app,host.docker.internal,localhost,127.0.0.1

# Loopback ports published on the host.
UI_OBSERVER_NOVNC_PORT=6080
UI_OBSERVER_CDP_PORT=9222
UI_OBSERVER_API_PORT=8090

# Virtual display / default viewport.
UI_OBSERVER_VIEWPORT_WIDTH=1440
UI_OBSERVER_VIEWPORT_HEIGHT=900

# ephemeral: clean profile each start, wiped afterwards (default).
# persistent: profile survives restarts in a named Docker volume.
UI_OBSERVER_PROFILE_MODE=ephemeral

# Evidence recording for missions.
UI_OBSERVER_RECORD_VIDEO=true
UI_OBSERVER_RECORD_TRACE=true

# Runs older than this are removed by `make cleanup`.
UI_OBSERVER_ARTIFACT_RETENTION_DAYS=14

# CI mode: headless missions, no noVNC. See docs/agent-integration.md.
UI_OBSERVER_HEADLESS=false
